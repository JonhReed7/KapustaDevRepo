# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=kapusta
DB_PORT_EXTERNAL=5432

# Backend
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/kapusta
DATABASE_URL_SYNC=postgresql://postgres:postgres@db:5432/kapusta
DB_HOST=db
DB_PORT=5432

# Auth
SECRET_KEY=change-me-to-a-real-secret-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# CORS
CORS_ORIGINS=["http://localhost:5173"]
